# ==============================================================================
# AGENCYBOT - CONFIGURATION EXAMPLE
# Copy this file to .env and fill in your actual values
# ==============================================================================

# ==============================================================================
# CORE APPLICATION
# ==============================================================================

# Node environment
NODE_ENV=production

# Application ID
VITE_APP_ID=your-app-id

# JWT Secret for session cookies (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# ==============================================================================
# DATABASE
# ==============================================================================

# MySQL/TiDB connection string
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://root:password@localhost:3306/agencybot

# ==============================================================================
# AUTHENTICATION (OAuth)
# ==============================================================================

# Your OAuth server URL (replace with your own domain)
OAUTH_SERVER_URL=https://auth.yourdomain.com

# Owner's OpenID for admin privileges
OWNER_OPEN_ID=user-openid-hash

# ==============================================================================
# LLM CONFIGURATION
# ==============================================================================

# Built-in LLM API URL and Key (required)
# This can be:
# - Your own LLM API endpoint
# - OpenAI compatible endpoint
# - Any other compatible service
BUILT_IN_FORGE_API_URL=https://your-llm-api.com/v1
BUILT_IN_FORGE_API_KEY=your-api-key-here

# ==============================================================================
# ENCRYPTION (for storing credentials securely)
# ==============================================================================

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_MASTER_KEY=your-encryption-key-base64-here

# ==============================================================================
# EXTERNAL SERVICES (Optional)
# ==============================================================================

# AWS S3 for file storage
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Twilio for voice calls
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Stripe for payments
STRIPE_SECRET_KEY=sk_live_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ==============================================================================
# LLM PROVIDER KEYS (Optional - for multi-provider support)
# ==============================================================================

# OpenAI
OPENAI_API_KEY=sk_your-openai-key

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant_your-anthropic-key

# Google Gemini
GOOGLE_API_KEY=your-google-api-key

# Groq
GROQ_API_KEY=your-groq-api-key

# ElevenLabs for text-to-speech
ELEVEN_LABS_API_KEY=your-elevenlabs-key

# Deepgram for speech-to-text
DEEPGRAM_API_KEY=your-deepgram-key

# ==============================================================================
# DEPLOYMENT (Railway, Vercel, etc.)
# ==============================================================================

# For Railway deployment
RAILWAY_TOKEN=your-railway-token

# For Vercel deployment
VERCEL_TOKEN=your-vercel-token

# ==============================================================================
# LOGGING & MONITORING (Optional)
# ==============================================================================

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Sentry for error tracking (optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
